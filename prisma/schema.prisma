generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeRole {
  ADMIN
  SELLER
}

enum PaymentMethod {
  CASH
  CARD
  QR
  TRANSFER
}

enum SaleStatus {
  COMPLETED
  RETURN_REQUESTED
  RETURNED
  CANCELLED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  WRITE_OFF
  INVENTORY
  TRANSFER
  ADJUSTMENT
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReorderStatus {
  NEEDS_ORDER
  ORDERED
  RECEIVED
}

enum CashShiftStatus {
  OPEN
  CLOSED
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id           String        @id @default(cuid())
  name         String        @unique
  phone        String?
  email        String?
  address      String?
  note         String?
  products     Product[]
  purchases    Purchase[]
  reorderItems ReorderItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Employee {
  id                 String            @id @default(cuid())
  name               String
  login              String            @unique
  passwordHash       String
  role               EmployeeRole      @default(SELLER)
  active             Boolean           @default(true)
  maxDiscountPercent Decimal           @default(5) @db.Decimal(5, 2)
  sales              Sale[]
  purchases          Purchase[]
  sessions           EmployeeSession[]
  stockMovements     StockMovement[]
  returnRequests     ReturnRequest[]   @relation("ReturnRequester")
  approvedReturns    ReturnRequest[]   @relation("ReturnApprover")
  auditLogs          AuditLog[]
  heldReceipts       HeldReceipt[]
  cashShifts         CashShift[]
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([deletedAt])
}

model EmployeeSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([expiresAt])
}

model Product {
  id                  String          @id @default(cuid())
  name                String
  slug                String          @unique
  imageUrl            String?
  subcategory         String?
  brand               String?
  sku                 String?         @unique
  barcode             String?         @unique
  price               Decimal         @db.Decimal(12, 2)
  cost                Decimal         @default(0) @db.Decimal(12, 2)
  unit                String
  stock               Decimal         @default(0) @db.Decimal(12, 2)
  minStock            Decimal         @default(0) @db.Decimal(12, 2)
  recommendedOrderQty Decimal         @default(0) @db.Decimal(12, 2)
  categoryId          String
  category            Category        @relation(fields: [categoryId], references: [id])
  supplierId          String?
  supplier            Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  warehouse           String?
  rack                String?
  shelf               String?
  description         String?
  powerW              Decimal?        @db.Decimal(10, 2)
  voltageV            String?
  socketType          String?
  lightColor          String?
  colorTemperatureK   Int?
  ipRating            String?
  size                String?
  color               String?
  material            String?
  cableLengthM        Decimal?        @db.Decimal(10, 2)
  wireSectionMm2      Decimal?        @db.Decimal(10, 2)
  active              Boolean         @default(true)
  saleItems           SaleItem[]
  purchaseItems       PurchaseItem[]
  stockMovements      StockMovement[]
  reorderItem         ReorderItem?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([categoryId])
  @@index([supplierId])
  @@index([name])
  @@index([brand])
  @@index([sku])
}

model Sale {
  id              String          @id @default(cuid())
  receiptNumber   String?         @unique
  subtotal        Decimal         @default(0) @db.Decimal(12, 2)
  discountPercent Decimal         @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(12, 2)
  total           Decimal         @db.Decimal(12, 2)
  paymentMethod   PaymentMethod   @default(CASH)
  status          SaleStatus      @default(COMPLETED)
  note            String?
  employeeId      String?
  employee        Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  shiftId         String?
  shift           CashShift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items           SaleItem[]
  stockMovements  StockMovement[]
  returnRequests  ReturnRequest[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([employeeId])
  @@index([shiftId])
  @@index([createdAt])
  @@index([status])
}

model CashShift {
  id             String          @id @default(cuid())
  status         CashShiftStatus @default(OPEN)
  openingCash    Decimal         @default(0) @db.Decimal(12, 2)
  closingCash    Decimal?        @db.Decimal(12, 2)
  cashSales      Decimal?        @db.Decimal(12, 2)
  expectedCash   Decimal?        @db.Decimal(12, 2)
  cashDifference Decimal?        @db.Decimal(12, 2)
  note           String?
  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id])
  sales          Sale[]
  openedAt       DateTime        @default(now())
  closedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([employeeId, status])
  @@index([openedAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  quantity  Decimal  @db.Decimal(12, 2)
  unitPrice Decimal  @db.Decimal(12, 2)
  unitCost  Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
}

model Purchase {
  id             String          @id @default(cuid())
  total          Decimal         @db.Decimal(12, 2)
  note           String?
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  employeeId     String?
  employee       Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  items          PurchaseItem[]
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([supplierId])
  @@index([employeeId])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Decimal  @db.Decimal(12, 2)
  unitCost   Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
}

model StockMovement {
  id           String            @id @default(cuid())
  type         StockMovementType
  quantity     Decimal           @db.Decimal(12, 2)
  stockBefore  Decimal           @db.Decimal(12, 2)
  stockAfter   Decimal           @db.Decimal(12, 2)
  note         String?
  fromLocation String?
  toLocation   String?
  productId    String
  product      Product           @relation(fields: [productId], references: [id])
  employeeId   String?
  employee     Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  saleId       String?
  sale         Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  purchaseId   String?
  purchase     Purchase?         @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())

  @@index([productId])
  @@index([employeeId])
  @@index([createdAt])
}

model ReturnRequest {
  id           String       @id @default(cuid())
  saleId       String
  sale         Sale         @relation(fields: [saleId], references: [id])
  employeeId   String
  employee     Employee     @relation("ReturnRequester", fields: [employeeId], references: [id])
  reason       String
  status       ReturnStatus @default(PENDING)
  approvedById String?
  approvedBy   Employee?    @relation("ReturnApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  adminNote    String?
  processedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([saleId])
  @@index([status])
}

model ReorderItem {
  id             String        @id @default(cuid())
  productId      String        @unique
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recommendedQty Decimal       @db.Decimal(12, 2)
  status         ReorderStatus @default(NEEDS_ORDER)
  orderedAt      DateTime?
  receivedAt     DateTime?
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())

  @@index([status])
}

model HeldReceipt {
  id              String        @id @default(cuid())
  name            String
  items           Json
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  paymentMethod   PaymentMethod @default(CASH)
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([employeeId])
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  details    Json?
  actorName  String
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([employeeId])
  @@index([createdAt])
  @@index([entityType, entityId])
}
